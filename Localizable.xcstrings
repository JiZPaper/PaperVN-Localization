    "筛选条件%@中的设置互相冲突。请调整其中一项。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The settings in filter %@ conflict with each other. Adjust one of them."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィルタ%@内の設定が競合しています。いずれかを調整してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필터 %@의 설정이 서로 충돌합니다. 설정 중 하나를 조정해 주세요."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "篩選條件%@中的設定互相衝突。請調整其中一項。"
          }
        }
      }
