    "感谢你的支持" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thank You for Your Support"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ご支援ありがとうございます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지원해 주셔서 감사합니다"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感謝你的支持"
